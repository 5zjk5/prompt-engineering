# ── 服务配置 ──────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=true

# ── 文件上传 ──────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=50

# ── 上下文压缩（可选，用于 Agent 场景） ────────────────────
CONTEXT_MAX_TOKENS=120000
CONTEXT_RESERVED_TOKENS=4096
CONTEXT_WARNING_THRESHOLD=0.70
CONTEXT_ERROR_THRESHOLD=0.90

# ── LLM 调用控制 ──────────────────────────────────────────
LLM_RETRY_COUNT=2
LLM_NON_STREAM_TIMEOUT=60
LLM_STREAM_FIRST_CHUNK_TIMEOUT=10
