{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "ChatExcel: 启动后端 (带调试)",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "main:app",
                "--host", "0.0.0.0",
                "--port", "7396",
                "--reload"
            ],
            "cwd": "${workspaceFolder}/backend",
            "python": "python",
            "env": {
                "PYTHONUNBUFFERED": "1",
                "DEBUG": "true"
            },
            "justMyCode": true,
            "console": "integratedTerminal"
        },
        {
            "name": "ChatExcel: 启动后端 (无 reload，断点稳定)",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "main:app",
                "--host", "0.0.0.0",
                "--port", "8000"
            ],
            "cwd": "${workspaceFolder}/backend",
            "python": "python",
            "env": {
                "PYTHONUNBUFFERED": "1",
                "DEBUG": "true"
            },
            "justMyCode": false,
            "console": "integratedTerminal"
        },
        {
            "name": "ChatExcel: 调试当前文件",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "cwd": "${workspaceFolder}/backend",
            "python": "python",
            "env": {
                "PYTHONUNBUFFERED": "1"
            },
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "Attach: 附加到运行中的后端 (端口 5678)",
            "type": "debugpy",
            "request": "attach",
            "connect": {
                "host": "localhost",
                "port": 5678
            },
            "justMyCode": false
        }
    ]
}
